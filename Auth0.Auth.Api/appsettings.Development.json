{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Information",
      "Microsoft.AspNetCore.Authentication": "Debug",
      "Microsoft.IdentityModel": "Debug"
    }
  },
  "Authentication": {
    "Domain": "dev-tenant.auth0.com",
    "Audience": "https://dev-api.example.com",
    "ClientId": "your-dev-client-id",
    "ClientSecret": "your-dev-client-secret",
    "AuthorizationUrl": "https://dev-tenant.auth0.com/authorize",
    "TokenUrl": "https://dev-tenant.auth0.com/oauth/token",
    "MetadataAddress": "https://dev-tenant.auth0.com/.well-known/openid-configuration",
    "ValidIssuer": "https://dev-tenant.auth0.com/"
  }
}
